# Server
HOST=127.0.0.1
PORT=3501
TICK_MS=1000
JSON_LIMIT=12mb

# Frontend
VITE_WS_URL=

# Market data: Twelve Data only.
MARKET_SYMBOL=XAU/USD
MARKET_INTERVAL=1min
MARKET_HISTORY_CANDLES=260

# MySQL persistence. Required.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=daytrading
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=5000
DB_AUTO_MIGRATE=true

# Twelve Data
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
TWELVE_DATA_WS_URL=wss://ws.twelvedata.com/v1/quotes/price
TWELVE_DATA_TIMEZONE=UTC
